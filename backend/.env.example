# Copy this file to backend/.env and fill in real values.

# MongoDB Atlas connection string:
# MONGODB_URI=mongodb+srv://<db_user>:<url_encoded_password>@<cluster-url>/fit_app?retryWrites=true&w=majority&appName=<AppName>

# Database name used by the app
DB_NAME=fit_app

# JWT secret for auth (must be long/random in shared or production environments)
SECRET_KEY=replace-with-a-long-random-secret

# Optional admin bootstrap credentials
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@fitapp.local
ADMIN_PASSWORD=change-this-password
